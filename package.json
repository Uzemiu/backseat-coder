{
  "name": "backseat-coder",
  "displayName": "Backseat Coder",
  "version": "0.1.0",
  "description": "AI pair coding guide that helps humans navigate unfamiliar codebases without taking the keyboard.",
  "publisher": "backseat-coder",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "categories": ["Other"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "backseat-coder.open",
        "title": "Backseat Coder: Open Sidebar"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "backseatCoder",
          "title": "Backseat Coder",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "backseatCoder": [
        {
          "type": "webview",
          "id": "backseatCoder.sidebar",
          "name": "Backseat Coder"
        }
      ]
    }
  },
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "test": "node --test"
  },
  "dependencies": {
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
